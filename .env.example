# Datadog API Credentials
# Get these from: https://app.datadoghq.com/organization-settings/api-keys
# Using DD_* prefix to match official Datadog SDK conventions
DD_API_KEY=your_api_key_here
DD_APP_KEY=your_app_key_here

# Datadog Site (optional, defaults to datadoghq.com)
# Options: datadoghq.com (US1), datadoghq.eu (EU), us3.datadoghq.com (US3), etc.
DD_SITE=datadoghq.com

# Logging (optional)
RUST_LOG=info
